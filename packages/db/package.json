{
  "name": "@delta/db",
  "version": "0.0.0",
  "private": true,
  "description": "Delta — client Supabase typé et repos (data access pur, sans HTTP)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./users": "./src/users/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .turbo coverage"
  },
  "dependencies": {
    "@delta/contracts": "workspace:*",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1"
  },
  "devDependencies": {
    "@delta/config": "workspace:*",
    "eslint": "^9.12.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.2"
  }
}
