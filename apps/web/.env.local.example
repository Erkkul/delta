# Template des variables d'environnement pour apps/web (Next.js).
#
# Copier en .env.local et remplir avec les vraies valeurs. .env.local est
# gitignored à la racine du repo (cf. .gitignore lignes 19-22).
#
# Pour Vercel : miroir manuel dans le dashboard Project Settings → Environment
# Variables (scopes Production + Preview + Development). Les valeurs marquées
# "sensitive" doivent être créées avec le toggle "Sensitive" activé côté Vercel
# pour qu'elles ne soient plus relisibles après création.
#
# Conventions de naming :
#   - NEXT_PUBLIC_* : inlinées dans le bundle client (exposables au browser)
#   - sans préfixe    : strictement côté serveur (route handlers, RSC, jobs)
# Cf. ARCHITECTURE.md §2.1 (sécurité données) et §9.5 (secrets).

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (public — exposable côté client)
# Source : Supabase Dashboard → Project Settings → API Keys
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://knyfrnxkqyyirnsyijfk.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (server-only — bypass RLS, jamais exposé au client)
# Une clé secret distincte par service backend (cf. ARCHITECTURE.md §18 entrée 1.3).
# Celle-ci est destinée à apps/web (route handlers serveur).
# Source : Supabase Dashboard → Project Settings → API Keys → "secret"
# Sensitive côté Vercel.
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Upstash Redis (server-only — rate-limit /auth/login)
# Source : Upstash Console → delta-dev-redis → REST API
# Sensitive côté Vercel.
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://REPLACE_ME-eu-west-1.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (public — clé exposable côté client, paiement acheteur)
# Source : Stripe Dashboard → Développeurs → Clés API → "Publishable key"
# Mode test : commence par pk_test_... ; mode live : pk_live_...
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (server-only — appels API, création Account Links, webhook handler)
# Sensitive côté Vercel.
# Source : Stripe Dashboard → Développeurs → Clés API → "Secret key"
# Mode test : sk_test_... ; mode live : sk_live_...
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Stripe Webhooks (server-only — vérification signature handler /webhooks/stripe)
# Deux secrets distincts car Stripe sépare les destinations « Votre compte » et
# « Comptes connectés » depuis l'UX Workbench (cf. tech/setup.md § Stripe Connect).
# Le handler essaie les deux à la vérification.
# Sensitive côté Vercel.
# Source : Stripe Dashboard → Workbench → Webhooks → endpoint → Clé secrète de signature
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET_PLATFORM=whsec_REPLACE_ME
STRIPE_WEBHOOK_SECRET_CONNECT=whsec_REPLACE_ME
